APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: set to your real HTTPS URL (no trailing slash). Never commit a real .env.
APP_URL=https://example.com

# Comma-separated IPs or * for platforms behind a reverse proxy / TLS termination
TRUSTED_PROXIES=*

# Set false on production so only seeded users can sign in
ALLOW_REGISTRATION=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_URL=
# DATABASE_URL=
# DB_HOST=
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# cPanel: when the site docroot is not Laravel's public/ (e.g. public_html) but the app is elsewhere,
# set the absolute filesystem path to the web root. Vite and storage:link will use this path.
# Example: LARAVEL_PUBLIC_PATH=/home/username/public_html
# LARAVEL_PUBLIC_PATH=

# Admin user (php artisan db:seed) — set a strong ADMIN_PASSWORD in production
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# Twilio Voice (webhooks: POST /incoming-call, POST /process-recording)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
TWILIO_VALIDATE_SIGNATURE=false

# OpenAI (Whisper STT, Chat, TTS)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Sarvam AI (fallback for STT / chat / TTS when OpenAI fails)
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v3
SARVAM_CHAT_MODEL=sarvam-30b
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=en-IN
# SARVAM_TTS_AUDIO_CODEC=
SARVAM_TTS_FILE_EXTENSION=wav
